{
  "image": "ghcr.io/embeddedcontainers/zephyr:riscv64-0.17.1SDK",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/app,type=bind",
  "workspaceFolder": "/workspace",
  "onCreateCommand": "bash -i /workspace/app/.devcontainer/onCreateCommand.sh",
  "mounts": [
    "source=${localWorkspaceFolder}/.vscode/,target=/workspace/.vscode,type=bind,consistency=cached"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        // Hush CMake
        "cmake.configureOnOpen": false,
        // IntelliSense
        "C_Cpp.default.compilerPath": "/opt/toolchains/zephyr-sdk-0.17.1/riscv64-zephyr-elf/bin/riscv64-zephyr-elf-gcc",
        "C_Cpp.default.compileCommands": "build/compile_commands.json",
        // File Associations
        "files.associations": {}
      },
      "extensions": [
        "ms-vscode.cpptools-extension-pack",
        "ms-python.python"
      ]
    }
  }
}